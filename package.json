{
  "name": "revision-brevet",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "App de révision du Brevet adaptée aux enfants dys (dyslexie, dysorthographie, dyscalculie)",
  "scripts": {
    "dev": "concurrently -n server,web -c blue,magenta \"npm:dev:server\" \"npm:dev:web\"",
    "dev:server": "node --watch server/index.js",
    "dev:web": "vite",
    "build": "vite build",
    "start": "node server/index.js",
    "preview": "npm run build && node server/index.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.0",
    "dotenv": "^17.0.0",
    "express": "^5.1.0",
    "multer": "^2.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "concurrently": "^9.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "vite": "^7.0.0"
  }
}
