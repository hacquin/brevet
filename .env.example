# Clé API Anthropic (obligatoire) — https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Modèles Claude utilisés, optimisés par type de tâche :
# - VISION : lecture du PDF scanné (tâche exigeante)   → défaut : claude-sonnet-4-6
# - TEXTE  : génération de quiz/épreuves (tâche facile) → défaut : claude-haiku-4-5
# Décommentez pour personnaliser :
# ANTHROPIC_MODEL_VISION=claude-sonnet-4-6
# ANTHROPIC_MODEL_TEXTE=claude-haiku-4-5
#
# Pour forcer UN SEUL modèle partout (ex. tout en Opus), définissez ANTHROPIC_MODEL :
# ANTHROPIC_MODEL=claude-opus-4-8

# Port du serveur (le serveur sert aussi l'app web en production)
PORT=3001
